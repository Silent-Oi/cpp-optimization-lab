* text=auto

# Keep cross-platform project files consistent with .editorconfig.
*.cmake text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
CMakeLists.txt text eol=lf

# Native Windows command scripts require Windows line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
